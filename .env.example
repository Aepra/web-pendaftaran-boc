# ====================================================================
# .env.example — Template untuk developer lain
# Copy file ini ke .env.local lalu isi nilai yang sesuai
# ====================================================================

# ======================
# Google Apps Script
# ======================
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ======================
# Google OAuth
# Dapatkan dari: https://console.cloud.google.com/apis/credentials
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ======================
# NextAuth.js
# NEXTAUTH_SECRET: generate dengan `npx auth secret`
# ======================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ======================
# Payment Gateway (Midtrans)
# Dapatkan dari dashboard Midtrans → Settings → Access Keys
# ======================
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_WEBHOOK_SECRET=

# ======================
# Email Service
# ======================
EMAIL_API_KEY=
EMAIL_FROM=panitia@boc2026.id

# ======================
# Payment Method Flags
# ======================
NEXT_PUBLIC_MIDTRANS_CODES=VA,QRIS,EWALLET,CREDIT_CARD
NEXT_PUBLIC_ORANG_DALAM_CODE=ORANG_DALAM

# ======================
# Contact Info Panitia
# ======================
NEXT_PUBLIC_WA_NUMBER=6281234567890
NEXT_PUBLIC_EMAIL=panitia@boc2026.id